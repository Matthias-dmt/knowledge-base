# Docusaurus deployment

# GitHub Pages — set to your GitHub org or username
# Used by `npm run deploy` (docusaurus deploy)
DOCUSAURUS_GIT_USER=your-github-username

# Optional: use an SSH key instead of password for deploy
# GIT_PASS is read by Docusaurus deploy command when USE_SSH is false
USE_SSH=false
# GIT_PASS=your-github-personal-access-token

# Optional: override the deployment branch (default: gh-pages)
# DEPLOYMENT_BRANCH=gh-pages

# Optional: override the target repo for deploy
# (defaults to projectName in docusaurus.config.ts)
# DEPLOYMENT_REPO=git@github.com:your-username/knowledge-base.git
